# Discord Bot Configuration
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_TOKEN=your_discord_token

# Single Discord server this bot serves (drop-in for the old multi-tenant scaffolding).
# Commands register to this guild for instant registration.
GUILD_ID=your_discord_guild_id

# SQLite database file. Locally a relative path; on Render this points at the mounted disk
# (see render.yaml -> DATABASE_PATH=/var/data/hermuz.db).
DATABASE_PATH=./hermuz.db

# HTTP port for the JSON API surface.
PORT=3000

# --- Web GUI / Discord OAuth2 ---
# Discord app OAuth2 client secret (Developer Portal → your app → OAuth2).
DISCORD_OAUTH_CLIENT_SECRET=your_discord_oauth_client_secret  # gitleaks:allow
# Secret used to sign session JWTs. Generate a long random string.
JWT_SECRET=your_long_random_jwt_secret  # gitleaks:allow
# Public origin of THIS API (Render URL in prod). OAuth callback = API_ORIGIN/auth/callback.
API_ORIGIN=http://localhost:3000
# Origin of the SPA (Netlify URL in prod). CORS allow-list + post-login redirect.
WEB_ORIGIN=http://localhost:5173
