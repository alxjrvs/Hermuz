# Discord Bot Configuration
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_TOKEN=your_discord_token

# Single Discord server this bot serves (drop-in for the old multi-tenant scaffolding).
# Commands register to this guild for instant registration.
GUILD_ID=your_discord_guild_id

# SQLite database file. Locally a relative path; on Render this points at the mounted disk
# (see render.yaml -> DATABASE_PATH=/var/data/hermuz.db).
DATABASE_PATH=./hermuz.db

# HTTP port for the JSON API surface (Phase 2).
PORT=3000

# --- Phase 2 (web GUI / Discord OAuth2), not yet wired ---
# DISCORD_OAUTH_CLIENT_SECRET=your_discord_oauth_client_secret  # gitleaks:allow
# SESSION_SECRET=your_session_secret  # gitleaks:allow
