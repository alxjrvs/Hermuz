{
  "name": "hermuz",
  "description": "Board-game scheduling assistant: Discord bot + web GUI over one shared SQLite core",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "keywords": [
    "bot",
    "discord",
    "discord.js",
    "drizzle",
    "sqlite",
    "typescript"
  ],
  "scripts": {
    "db:generate": "bun --filter '@hermuz/db' generate",
    "db:migrate": "bun --filter '@hermuz/db' migrate",
    "lint": "eslint -c config/eslint.js . && prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/bun": "latest",
    "@types/node": "^22.15.18",
    "eslint": "9",
    "globals": "^16.1.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
