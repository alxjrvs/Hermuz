{
  "name": "hermuz",
  "description": "Board-game scheduling assistant: Discord bot + web GUI over one shared SQLite core",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "keywords": [
    "bot",
    "discord",
    "discord.js",
    "drizzle",
    "sqlite",
    "typescript"
  ],
  "scripts": {
    "db:generate": "bun --filter '@hermuz/db' generate",
    "db:migrate": "bun --filter '@hermuz/db' migrate",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "latest",
    "@types/node": "^22.15.18",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "typescript": "^5.8.3"
  }
}
